{
    "manifest_version": 3,
    "name": "RecruitAI - LinkedIn Connector",
    "version": "1.0.0",
    "description": "Seamlessly save LinkedIn profiles to your RecruitAI CRM.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "externally_connectable": {
        "matches": [
            "http://localhost:3000/*"
        ]
    },
    "host_permissions": [
        "*://*.linkedin.com/*",
        "http://localhost:8089/*"
    ],
    "action": {},
    "background": {
        "service_worker": "scripts/background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.linkedin.com/in/*"
            ],
            "js": [
                "scripts/content.js"
            ]
        }
    ]
}